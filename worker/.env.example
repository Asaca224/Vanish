# Vanish worker configuration (spec §7).

# Deployed control-plane base URL (no trailing slash).
CONTROL_PLANE_URL="https://your-app.vercel.app"

# Must match WORKER_TOKEN set in the control-plane environment.
WORKER_TOKEN="shared-worker-token"

# Optional.
WORKER_ID="laptop-worker"
POLL_INTERVAL_MS="5000"
# Headed by default so you can clear CAPTCHAs / upload IDs. Set true only for
# jobs you know won't need a human.
HEADLESS="false"
