# ---------------------------------------------------------------------------
# Vanish environment variables
#
# Copy to .env.local for local dev, and set the same keys in Vercel project
# settings for production. NEVER commit real secrets to the repo (§2.1).
# ---------------------------------------------------------------------------

# --- Database (Neon Postgres) ---------------------------------------------
# Use Neon's POOLED connection string for the app (serverless-safe), and the
# DIRECT (unpooled) string for Prisma migrations.
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/vanish?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/vanish?sslmode=require"

# --- App-level PII encryption (§2.1) --------------------------------------
# 32-byte key, base64-encoded. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# This key protects every identity attribute at the app layer. Losing it makes
# encrypted PII unrecoverable. Rotate via PII_ENCRYPTION_KEY_PREVIOUS.
PII_ENCRYPTION_KEY="base64-32-byte-key"
# Optional: previous key kept during a rotation window so old rows still decrypt.
PII_ENCRYPTION_KEY_PREVIOUS=""

# --- Auth.js (NextAuth) + Google/Gmail OAuth (§10) ------------------------
# Generate AUTH_SECRET with: npx auth secret
AUTH_SECRET="random-secret"
AUTH_URL="http://localhost:3000"
# Google Cloud OAuth client (request gmail.readonly scope in consent screen).
AUTH_GOOGLE_ID="xxxx.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="google-oauth-client-secret"
# Only this email may sign in (single-tenant MVP, §2.1).
OPERATOR_EMAIL="you@gmail.com"

# --- Resend (outbound email, §10) -----------------------------------------
RESEND_API_KEY="re_xxxx"
# Must be a domain you have verified in Resend — NOT your gmail.com address.
RESEND_FROM="privacy@yourdomain.com"

# --- Vercel Cron auth (§8) ------------------------------------------------
# Shared secret the cron endpoints require in the Authorization header.
CRON_SECRET="random-cron-secret"

# --- Dev login (optional; bypasses Google OAuth) --------------------------
# When set, GET /api/dev-login?secret=<this> mints a session for OPERATOR_EMAIL
# (as admin) without Google. Use to get in while the OAuth consent screen is in
# "testing". Leave UNSET in a real production deployment to disable it.
DEV_LOGIN_SECRET=""

# --- Optional AI assist (§7) ----------------------------------------------
# Leave unset to disable. When set, only minimal fields are sent (§7).
ANTHROPIC_API_KEY=""
AI_ASSIST_ENABLED="false"
