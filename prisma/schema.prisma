// Vanish data model — v3 (multi-user). Spec §10.
// Storage: Neon (Postgres). All PII values are field-encrypted at the app layer
// BEFORE they reach Postgres (see src/lib/crypto.ts). Columns holding ciphertext
// are suffixed `Encrypted` and are opaque blobs to the DB. Every user-owned row
// carries userId and MUST be queried scoped by it — no cross-user reads (§2.1).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Auth.js (NextAuth) models — the User IS the data subject (multi-user).
// ---------------------------------------------------------------------------

enum Role {
  user
  admin
}

enum ConfirmationSource {
  gmail
  forwarding
  none
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  role Role @default(user)

  // Electronic authorized-agent consent captured at signup (§2.2).
  authorizationSignedAt DateTime?
  consentVersion        String?

  // Drives channel routing (CA residents → DROP) and confirmation handling.
  residencyState     String?
  confirmationSource ConfirmationSource @default(none)
  // Per-user inbound forwarding token: confirm+<token>@domain (§2.2 MVP path).
  forwardingToken    String?            @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts           Account[]
  sessions           Session[]
  attributes         IdentityAttribute[]
  listings           Listing[]
  removalRequests    RemovalRequest[]
  channelSubmissions ChannelSubmission[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum AttributeType {
  name
  alias
  email
  phone
  address_current
  address_prior
  dob
  relative
}

enum RemovalMethod {
  drop
  email
  web_form
  postal
  manual_only
}

enum BrokerStatus {
  proposed // discovered, awaiting admin review (§8)
  approved // admin-approved, ready to go live
  live // in user-facing scanning/removal
  retired
  rejected
}

enum BrokerSource {
  seed
  ca_registry
  discovery
  manual
}

enum ListingStatus {
  candidate
  confirmed
  rejected
}

enum Channel {
  drop
  email
  web_form
  postal
}

// RemovalRequest lifecycle (spec §6).
enum RequestState {
  discovered
  queued
  in_progress
  awaiting_user
  awaiting_user_verification
  submitted
  awaiting_confirmation
  confirmed
  verifying
  removed
  // terminal / side states
  exempt
  failed
  blocked
  skipped_covered_by_drop
}

enum EvidenceKind {
  screenshot
  email_ref
  request_id
  pdf
}

enum DiscoveryTrigger {
  cron
  admin
}

enum CandidateDisposition {
  proposed
  rejected
  duplicate
}

enum WorkerJobType {
  scan
  web_form_removal
  fetch_page
}

enum WorkerJobState {
  queued
  in_progress
  done
  failed
}

// ---------------------------------------------------------------------------
// User-owned domain models — all scoped by userId (§2.1)
// ---------------------------------------------------------------------------

model IdentityAttribute {
  id             String        @id @default(cuid())
  userId         String
  type           AttributeType
  valueEncrypted String        @db.Text
  // Keyed HMAC blind index for de-dup without plaintext. Never the plaintext.
  valueHash      String?
  isPrimary      Boolean       @default(false)
  verified       Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, valueHash])
  @@index([userId])
}

model Listing {
  id              String        @id @default(cuid())
  userId          String
  brokerId        String
  profileUrl      String?
  matchedFields   Json?
  matchConfidence Float         @default(0)
  status          ListingStatus @default(candidate)
  discoveredAt    DateTime      @default(now())

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  broker          Broker           @relation(fields: [brokerId], references: [id], onDelete: Cascade)
  removalRequests RemovalRequest[]

  @@index([userId])
  @@index([brokerId])
  @@index([status])
}

model RemovalRequest {
  id                   String       @id @default(cuid())
  userId               String
  brokerId             String
  listingId            String?
  channel              Channel
  state                RequestState @default(discovered)
  confirmationRequired Boolean      @default(false)
  submittedAt          DateTime?
  confirmedAt          DateTime?
  verifiedRemovedAt    DateTime?
  nextRecheckAt        DateTime?
  exemptReason         String?
  failureReason        String?
  channelSubmissionId  String?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  broker            Broker             @relation(fields: [brokerId], references: [id], onDelete: Cascade)
  listing           Listing?           @relation(fields: [listingId], references: [id], onDelete: SetNull)
  channelSubmission ChannelSubmission? @relation(fields: [channelSubmissionId], references: [id], onDelete: SetNull)
  evidence          Evidence[]
  events            RequestEvent[]

  @@index([userId])
  @@index([state])
  @@index([nextRecheckAt])
  @@index([channelSubmissionId])
}

model RequestEvent {
  id               String        @id @default(cuid())
  removalRequestId String
  fromState        RequestState?
  toState          RequestState
  note             String?
  createdAt        DateTime      @default(now())

  removalRequest RemovalRequest @relation(fields: [removalRequestId], references: [id], onDelete: Cascade)

  @@index([removalRequestId])
}

model ChannelSubmission {
  id               String    @id @default(cuid())
  userId           String
  channel          Channel   @default(drop)
  submittedAt      DateTime  @default(now())
  requestReference String?
  coversBrokerIds  Json
  retrieveByAt     DateTime?
  finalizeByAt     DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  removalRequests RemovalRequest[]

  @@index([userId])
}

model Evidence {
  id               String       @id @default(cuid())
  removalRequestId String
  kind             EvidenceKind
  blobRef          String       @db.Text
  capturedAt       DateTime     @default(now())

  removalRequest RemovalRequest @relation(fields: [removalRequestId], references: [id], onDelete: Cascade)

  @@index([removalRequestId])
}

// ---------------------------------------------------------------------------
// Shared / global models
// ---------------------------------------------------------------------------

model Broker {
  id                    String        @id @default(cuid())
  name                  String
  domain                String        @unique
  optOutUrl             String?
  removalMethod         RemovalMethod
  requiresCaptcha       Boolean       @default(false)
  requiresId            Boolean       @default(false)
  confirmationEmailFrom String?
  optOutEmail           String?
  recheckDays           Int           @default(30)
  caRegistered          Boolean       @default(false)
  coveredByDrop         Boolean       @default(false)
  adapterKey            String?
  status                BrokerStatus  @default(proposed)
  source                BrokerSource  @default(manual)
  // Evidence snippets backing an auto-discovered proposal (§8.4).
  evidence              Json?
  discoveryConfidence   Float?
  notes                 String?       @db.Text
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  listings        Listing[]
  removalRequests RemovalRequest[]

  @@index([removalMethod])
  @@index([caRegistered])
  @@index([status])
}

// History of domains the discovery pipeline has seen, so a rejected domain is
// not re-proposed every run (§8.2).
model DiscoveryCandidate {
  id          String               @id @default(cuid())
  domain      String               @unique
  firstSeen   DateTime             @default(now())
  lastSeen    DateTime             @updatedAt
  disposition CandidateDisposition @default(proposed)
  runId       String?

  run DiscoveryRun? @relation(fields: [runId], references: [id], onDelete: SetNull)

  @@index([disposition])
}

model DiscoveryRun {
  id         String           @id @default(cuid())
  trigger    DiscoveryTrigger
  startedAt  DateTime         @default(now())
  finishedAt DateTime?
  // { queries, candidatesFound, proposed, duplicates, rejected, tokens, error }
  stats      Json?
  error      String?          @db.Text

  candidates DiscoveryCandidate[]

  @@index([startedAt])
}

// Job queue drained by the browser-automation worker (§7).
model WorkerJob {
  id         String         @id @default(cuid())
  type       WorkerJobType
  payload    Json
  state      WorkerJobState @default(queued)
  result     Json?
  lockedBy   String?
  lockedAt   DateTime?
  attempts   Int            @default(0)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([state, type])
}
